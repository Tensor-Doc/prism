# Copy to .env and fill in. NEVER commit a real .env — it's gitignored
# for a reason. See README.md "Environment variables" for what each
# var does and where to get the keys.

# ─── Required: website ─────────────────────────────────────
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=
VITE_NASA_API_KEY=

# ─── Required: Unsplash image source ───────────────────────
UNSPLASH_ACCESS_KEY=
UNSPLASH_APPLICATION_ID=
UNSPLASH_SECRET_KEY=

# ─── Required: Cloudflare R2 (catalog video uploads + dev
#                              image-feed cache) ──────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=
# R2_KEY_PREFIX=

# ─── Optional toggles (see README) ─────────────────────────
# UNSPLASH_R2_ENABLED=true
# UNSPLASH_R2_CAP=50
# UNSPLASH_TRACK_ENABLED=false
# CRON_SECRET=
