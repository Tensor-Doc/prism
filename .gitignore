node_modules/
dist/
.DS_Store
*.log
*~
.env
.env.local
!.env.example
.vite/
.vercel
tsconfig.tsbuildinfo

# Operational state — gets regenerated by the pipeline. Source of truth
# is in catalog/entries/*.json.
catalog/.ingest-progress.json

# Rendered preset videos + thumbnails. Once uploaded to R2 (M5b), the
# entry.assets.video / .thumb fields hold public R2 URLs; local files
# are scratch artifacts of the render pipeline.
public/videos/
public/thumbs/

# Recorded test-signal audio (e.g. Pink Floyd Money 1:10-1:40). Local
# only — copyright lives with the original artist. The annotation
# pipeline uses it as a deterministic stimulus across all 526 captures
# but it doesn't ship in the public site.
public/audio/test-signal.webm

# Generated by `pnpm prism build-index`. Source of truth is
# catalog/entries/*.json; this file is rebuilt at deploy time so it's
# always in sync with the entries on the deployed branch.
public/catalog/index.json

# Upstream preset/texture sources used as ingest input. The canonical
# copies live in public/presets/ + public/textures/ after `pnpm prism
# ingest`; favorites/ stays local-only.
favorites/

# Per-iteration shader generation outputs (atlases, screenshots,
# critiques). The source of truth is concepts/shaders.json +
# concepts/prompts/; iter-NNN directories are regeneratable scratch.
concepts/iterations/

# Claude Code local state (per-user; not for the repo).
.claude/

# Standalone smoke-test scripts written during particles backend
# bring-up. Useful as references but not stable enough for CI.
scripts/particles-smoke.mjs
scripts/particles-frames.mjs
