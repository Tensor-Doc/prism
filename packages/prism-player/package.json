{
  "name": "prism-player",
  "version": "0.0.0",
  "description": "Two-line embed for Prism audio-reactive visualizations.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "milkdrop-preset-converter": "^0.1.2"
  },
  "peerDependenciesMeta": {
    "butterchurn": {
      "optional": true
    },
    "butterchurn-presets": {
      "optional": true
    },
    "milkdrop-preset-converter": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/prism-player.cjs",
    "module": "./dist/prism-player.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/prism-player.mjs",
        "require": "./dist/prism-player.cjs"
      }
    }
  }
}
