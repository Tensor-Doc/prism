{
  "name": "@Tensor-Doc/prism",
  "version": "0.1.1",
  "description": "Two-line embed for audio-reactive visualizations. Milkdrop + Shadertoy in a single PrismPlayer class.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "audio-reactive",
    "visualization",
    "milkdrop",
    "butterchurn",
    "shadertoy",
    "music-visualizer",
    "webgl",
    "shader"
  ],
  "homepage": "https://prism.scott.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tensor-Doc/prism.git",
    "directory": "packages/prism"
  },
  "bugs": "https://github.com/Tensor-Doc/prism/issues",
  "author": "Scott Penberthy (https://scott.ai)",
  "dependencies": {
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "milkdrop-preset-converter": "^0.1.2"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/prism.cjs",
    "module": "./dist/prism.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/prism.mjs",
        "require": "./dist/prism.cjs"
      }
    }
  }
}
